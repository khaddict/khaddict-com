    const STATUS = 'https://status.khaddict.com';
    const SLUG   = 'khaddict';

    const dot      = document.getElementById('s-dot');
    const dropdown = document.getElementById('s-dropdown');
    const inner    = document.getElementById('s-inner');
    const btn      = document.getElementById('status-btn');

    let lastStatusFetch = null;
    function updateStatusFreshness() {
      const el = document.getElementById('status-updated');
      if (!el || !lastStatusFetch) return;
      const secs = Math.max(0, Math.round((Date.now() - lastStatusFetch) / 1000));
      el.textContent = t('status.updatedAgo').replace('{n}', secs);
    }
    setInterval(updateStatusFreshness, 5000);

    async function loadStatus() {
      try {
        const [pageRes, hbRes] = await Promise.all([
          fetch(`${STATUS}/api/status-page/${SLUG}`),
          fetch(`${STATUS}/api/status-page/heartbeat/${SLUG}`)
        ]);
        if (!pageRes.ok || !hbRes.ok) throw new Error();

        const page = await pageRes.json();
        const hb   = await hbRes.json();
        const monitors = page.publicGroupList.flatMap(g => g.monitorList);
        let up = 0;
        const pctValues = [];

        const rows = monitors.map(m => {
          const beats = hb.heartbeatList[m.id] || [];
          const last  = beats[beats.length - 1];
          const isUp  = last?.status === 1;
          if (isUp) up++;

          const pct24  = hb.uptimeList[`${m.id}_24`];
          const pctNum = pct24 !== undefined ? pct24 * 100 : undefined;
          if (pctNum !== undefined) pctValues.push(pctNum);
          const p = pctNum !== undefined ? `${pctNum.toFixed(1)}%` : '—';
          const pctCls = pctNum === undefined ? '' : pctNum >= 99 ? 'good' : pctNum >= 95 ? 'mid' : 'bad';
          const dotCls = isUp ? (pctNum !== undefined && pctNum < 95 ? 'warn' : 'up') : 'down';

          const recent = beats.slice(-30);
          const bars = recent.map(b => {
            const state = b.status === 1 ? 'up' : b.status === 0 ? 'down' : b.status === 2 ? 'pending' : '';
            const title = b.time ? new Date(b.time).toLocaleString(currentLang === 'fr' ? 'fr-FR' : 'en-US', { hour: '2-digit', minute: '2-digit' }) : '';
            return `<span class="heartbeat-bar ${state}"${title ? ` title="${title}"` : ''}></span>`;
          }).join('');

          return `
            <div class="dropdown-line">
              <div class="dropdown-line-top">
                <span class="dot ${dotCls}"></span>
                <span class="dropdown-name">${m.name}</span>
                <span class="pct ${pctCls}">${p}</span>
              </div>
              <div class="heartbeat">${bars}</div>
            </div>`;
        }).join('');

        const total = monitors.length;
        const worstPct = pctValues.length ? Math.min(...pctValues) : 100;
        let level, summaryKey;
        if (up === total && worstPct >= 99) { level = 'up'; summaryKey = 'status.allUp'; }
        else if (up === 0) { level = 'down'; summaryKey = 'status.majorOutage'; }
        else { level = 'warn'; summaryKey = 'status.partial'; }

        inner.innerHTML = `
          <div class="summary-line"><span class="status-dot ${level}"></span>${t(summaryKey)}</div>
          ${rows}
          <a class="dropdown-more" href="${STATUS}" target="_blank" rel="noopener">${t('status.viewFull')}</a>
          <div class="status-updated" id="status-updated"></div>
        `;

        btn.classList.remove('warn-pill', 'down-pill');
        if (level === 'warn') btn.classList.add('warn-pill');
        if (level === 'down') btn.classList.add('down-pill');
        dot.className = `dot ${level}`;

        lastStatusFetch = Date.now();
        updateStatusFreshness();

      } catch {
        inner.innerHTML = `<div class="dropdown-line dropdown-msg">${t('status.unreachable')}</div>`;
      }
    }

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.toggle('open');
      btn.setAttribute('aria-expanded', isOpen);
    });
    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target) && e.target !== btn) {
        dropdown.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });

    loadStatus();
