<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script>
{% include "partials/theme_toggle.js.j2" %}
  </script>
  <title>{{ i18n['title.home'] }}</title>
  <meta name="description" content="{{ meta_description }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ og_url }}" />
  <meta property="og:title" content="khaddict" />
  <meta property="og:description" content="{{ meta_description }}" />
  <meta property="og:image" content="https://images.khaddict.com/icons/khazix-pc-flat.png" />
  <meta property="og:locale" content="{{ og_locale }}" />
  <meta property="og:locale:alternate" content="{{ og_locale_alternate }}" />
  <link rel="canonical" href="{{ canonical_url }}" />
  <link rel="alternate" hreflang="en" href="https://khaddict.com/" />
  <link rel="alternate" hreflang="fr" href="https://khaddict.com/fr/" />
  <link rel="alternate" hreflang="x-default" href="https://khaddict.com/" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="khaddict" />
  <meta name="twitter:image" content="https://images.khaddict.com/icons/khazix-pc-flat.png" />
  <link rel="icon" href="https://images.khaddict.com/icons/khazix-pc-flat.png" type="image/png" />
  <link rel="apple-touch-icon" href="https://images.khaddict.com/icons/khazix-pc-flat.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />

  <!-- Matomo -->
  <script>
    var _paq = window._paq = window._paq || [];
    _paq.push(['trackPageView']);
    _paq.push(['enableLinkTracking']);
    (function() {
      var u="//matomo.khaddict.com/";
      _paq.push(['setTrackerUrl', u+'matomo.php']);
      _paq.push(['setSiteId', '1']);
      var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
      g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
    })();
  </script>
  <!-- End Matomo -->

  <style>
{% include "partials/head_tokens.css.j2" %}
{% include "partials/status_widget.css.j2" %}
    /* hero */
    .hero {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem 1.5rem;
      animation: fade-up .45s ease both;
    }

    .hero-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 3rem;
      max-width: 1180px;
      width: 100%;
    }

    .hero-copy { flex: 1 1 320px; text-align: left; }

    .hero h1 {
      font-size: clamp(1.5rem, 4vw, 2.1rem);
      font-weight: 700;
      line-height: 1.4;
      max-width: 420px;
      letter-spacing: -.02em;
    }

    @media (max-width: 940px) {
      .hero-row { flex-direction: column; text-align: center; gap: 2rem; }
      .hero-copy { flex: none; text-align: center; max-width: 100%; }
      .hero h1 { max-width: 100%; margin: 0 auto; }
    }

    .hero .highlight {
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .repo-link {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      margin-top: .9rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: .8rem;
      color: var(--muted);
      text-decoration: none;
      transition: color .15s ease;
    }
    .repo-link:hover { color: var(--accent); }
    .repo-link svg { width: 14px; height: 14px; }

    /* deploy gag, relocated from the now-retired blog.khaddict.com */
    .deploy-panel {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.1rem;
      padding: 1.75rem 2rem;
      border-radius: 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      box-shadow: 0 20px 50px var(--shadow);
      flex: 1 1 620px;
      max-width: 720px;
      width: 100%;
      overflow: hidden;
      transition: background-color .2s ease, border-color .2s ease;
    }

    .deploy-panel::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--down), transparent);
    }

    .deploy-panel::after {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 50% at 50% 0%, var(--danger-dim), transparent 70%);
      pointer-events: none;
    }

    .deploy-label {
      position: relative;
      font-family: 'JetBrains Mono', monospace;
      font-size: .68rem;
      font-weight: 600;
      color: var(--down);
      letter-spacing: .14em;
      text-transform: uppercase;
      opacity: .85;
    }

    .deploy-title { position: relative; font-size: 1.02rem; font-weight: 700; line-height: 1.5; }
    .deploy-title strong { color: var(--down); font-weight: 800; }

    .deploy-sub {
      position: relative;
      font-size: .78rem;
      color: var(--muted);
      line-height: 1.6;
      max-width: 620px;
      white-space: nowrap;
    }

    @media (max-width: 940px) {
      .deploy-panel { flex: none; }
      .deploy-sub { white-space: normal; max-width: 420px; }
    }

    .deploy-btn {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .5rem;
      padding: .6rem 1.4rem;
      border-radius: 10px;
      border: 1px solid rgba(239, 68, 68, .35);
      background: rgba(239, 68, 68, .08);
      color: var(--down);
      font-family: 'JetBrains Mono', monospace;
      font-size: .82rem;
      font-weight: 600;
      letter-spacing: .03em;
      cursor: pointer;
      transition: background .2s, border-color .2s, box-shadow .2s, transform .15s cubic-bezier(.34, 1.56, .64, 1);
    }

    .deploy-btn:hover:not(:disabled) {
      background: rgba(239, 68, 68, .16);
      border-color: rgba(239, 68, 68, .65);
      box-shadow: 0 0 24px rgba(239, 68, 68, .2);
      transform: translateY(-3px);
    }

    .deploy-btn.deploying {
      cursor: not-allowed;
      transform: none;
      animation: deploy-progress 16.85s linear forwards;
    }

    @keyframes deploy-progress {
      0%   { background: rgba(239, 68, 68, .10); border-color: rgba(239, 68, 68, .4);  color: #ef4444; }
      100% { background: rgba(34, 197, 94, .10); border-color: rgba(34, 197, 94, .45); color: #22c55e; }
    }

    .deploy-btn:disabled { opacity: .75; }

    .deploy-spinner {
      width: 13px; height: 13px;
      border: 2px solid var(--border);
      border-top-color: currentColor;
      border-radius: 50%;
      animation: spin .7s linear infinite;
    }

    .confetti-container {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 999;
    }

    .confetti-piece {
      position: fixed;
      width: 8px;
      height: 8px;
      border-radius: 2px;
      animation: confetti-burst .9s ease-out forwards;
    }

    @keyframes confetti-burst {
      to {
        transform: translate(var(--dx), calc(var(--dy) + 240px)) rotate(var(--rot));
        opacity: 0;
      }
    }

    #deploy-log {
      position: relative;
      display: none;
      width: calc(100% + 4rem);
      margin: .5rem -2rem -1.75rem;
      padding: .85rem 1.5rem 1.1rem;
      background: #0a0a0f;
      border-top: 1px solid var(--border);
      font-family: 'JetBrains Mono', monospace;
      font-size: .72rem;
      line-height: 1.8;
      text-align: left;
      white-space: pre-wrap;
      overflow-y: auto;
      overflow-x: hidden;
      user-select: none;
    }

    #deploy-log.open { display: flex; flex-direction: column; height: min(300px, 40dvh); }

    #deploy-log .la { color: var(--accent); }
    #deploy-log .lg { color: #4ade80; }
    #deploy-log .lm { color: #8a8a96; }

    #deploy-log::-webkit-scrollbar { width: 3px; }
    #deploy-log::-webkit-scrollbar-track { background: transparent; }
    #deploy-log::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, .12); border-radius: 2px; }
    #deploy-log::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, .22); }

    @keyframes spin { to { transform: rotate(360deg); } }

    @keyframes fade-up {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
{% include "partials/responsive.css.j2" %}
  </style>
</head>

<body>
{% include "partials/header.html.j2" %}

  <main class="hero">
    <div class="hero-row">
      <div class="hero-copy">
        <h1 data-i18n="hero.title">{{ i18n['hero.title'] | safe }}</h1>
        <a class="repo-link" href="https://github.com/khaddict/voidnode" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-1.03-.01-1.87-2.78.62-3.37-1.21-3.37-1.21-.46-1.19-1.11-1.51-1.11-1.51-.91-.64.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.72 0 0 .84-.28 2.75 1.05a9.3 9.3 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.46.1 2.72.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.6.69.49A10.03 10.03 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"/></svg>
