            parrotInterval = setInterval(() => {
              const nearBottom = deployLog.scrollHeight - deployLog.scrollTop - deployLog.clientHeight < 40;
              const lines = poses[fi % poses.length];
              const color = RAINBOW[Math.floor(Math.random() * RAINBOW.length)];
              fi++;
              wrap.innerHTML = '';
              wrap.style.color = color;
              lines.forEach(txt => {
                const d = document.createElement('div');
                d.textContent = txt;
                wrap.appendChild(d);
              });
              if (nearBottom) deployLog.scrollTop = deployLog.scrollHeight;
            }, 75);

            stopParrot = () => {
              clearInterval(parrotInterval);
              document.removeEventListener('keydown', cancelHandler);
              deployLog.removeEventListener('click', stopParrot);
              window.open(RICK, '_blank', 'noopener');
              awaitReturnAndCelebrate();

              const nearBottom = deployLog.scrollHeight - deployLog.scrollTop - deployLog.clientHeight < 40;
              wrap.innerHTML = '';
              wrap.style.color = '';

              const ctrlC = document.createElement('div');
              ctrlC.className = 'lm';
              ctrlC.textContent = '^C';
              deployLog.appendChild(ctrlC);

              const cmd = document.createElement('div');
              cmd.innerHTML = '<span class="la">$ cat ~/.gotcha</span>';
              deployLog.appendChild(cmd);

              const gotcha = document.createElement('div');
              gotcha.className = 'lg';
              gotcha.textContent = 'well played... by me. 🕺';
              deployLog.appendChild(gotcha);

              if (nearBottom) deployLog.scrollTop = deployLog.scrollHeight;
            };
            cancelHandler = (e) => {
              const isCtrlC = (e.ctrlKey || e.metaKey) && (e.key === 'c' || e.key === 'C');
              if (!isCtrlC) return;
              e.preventDefault();
              stopParrot();
            };
            document.addEventListener('keydown', cancelHandler);
            deployLog.addEventListener('click', stopParrot);

          }, 400);
        }, 16850);
      }

      function awaitReturnAndCelebrate() {
        const onVisible = () => {
          if (document.visibilityState !== 'visible') return;
          document.removeEventListener('visibilitychange', onVisible);
          setTimeout(() => {
            deployBtn.innerHTML = `${t('deploy.deployed')} <span aria-hidden="true">✓</span>`;
            spawnConfetti(deployBtn);
          }, 1000);
        };
        document.addEventListener('visibilitychange', onVisible);
      }

      function spawnConfetti(anchor) {
        const rect = anchor.getBoundingClientRect();
        const originX = rect.left + rect.width / 2;
        const originY = rect.top + rect.height / 2;
        const colors = ['#8b5cf6', '#c026d3', '#4ade80', '#fbbf24', '#38bdf8'];

        const container = document.createElement('div');
        container.className = 'confetti-container';
        document.body.appendChild(container);

        for (let i = 0; i < 110; i++) {
          const piece = document.createElement('span');
          piece.className = 'confetti-piece';
          const angle = Math.random() * Math.PI * 2;
          const distance = 80 + Math.random() * 160;
          piece.style.left = originX + 'px';
          piece.style.top = originY + 'px';
          piece.style.background = colors[i % colors.length];
          piece.style.setProperty('--dx', (Math.cos(angle) * distance) + 'px');
          piece.style.setProperty('--dy', (Math.sin(angle) * distance - 60) + 'px');
          piece.style.setProperty('--rot', (Math.random() * 720 - 360) + 'deg');
          piece.style.animationDelay = (Math.random() * .15) + 's';
          container.appendChild(piece);
        }

        setTimeout(() => container.remove(), 1500);
      }

      deployBtn.addEventListener('click', deploy);

      window.addEventListener('pageshow', () => {
        fired = false;
        if (parrotInterval) clearInterval(parrotInterval);
        if (cancelHandler) document.removeEventListener('keydown', cancelHandler);
        if (stopParrot) deployLog.removeEventListener('click', stopParrot);
        deployBtn.disabled = false;
        deployBtn.classList.remove('deploying');
        deployBtn.textContent = t('deploy.button');
        deployLog.classList.remove('open');
        deployLog.innerHTML = '';
      });
