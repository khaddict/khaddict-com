      function line(text, cls, delay) {
        setTimeout(() => {
          const nearBottom = deployLog.scrollHeight - deployLog.scrollTop - deployLog.clientHeight < 40;
          const d = document.createElement('div');
          if (cls) d.className = cls;
          d.textContent = text;
          deployLog.appendChild(d);
          if (nearBottom) deployLog.scrollTop = deployLog.scrollHeight;
        }, delay);
