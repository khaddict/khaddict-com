{% from "partials/js_str.j2" import js_str %}
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script>
{% include "partials/theme_toggle.js.j2" %}
  </script>
  <title>{{ i18n['title.projects'] }}</title>
  <meta name="description" content="{{ meta_description }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ og_url }}" />
  <meta property="og:title" content="{{ i18n['title.projects'] }}" />
  <meta property="og:description" content="{{ meta_description }}" />
  <meta property="og:image" content="https://images.khaddict.com/icons/khazix-pc-flat.png" />
  <meta property="og:locale" content="{{ og_locale }}" />
  <meta property="og:locale:alternate" content="{{ og_locale_alternate }}" />
  <link rel="canonical" href="{{ canonical_url }}" />
  <link rel="alternate" hreflang="en" href="https://projects.khaddict.com/" />
  <link rel="alternate" hreflang="fr" href="https://projects.khaddict.com/fr/" />
  <link rel="alternate" hreflang="x-default" href="https://projects.khaddict.com/" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="{{ i18n['title.projects'] }}" />
  <meta name="twitter:image" content="https://images.khaddict.com/icons/khazix-pc-flat.png" />
  <link rel="icon" href="https://images.khaddict.com/icons/khazix-pc-flat.png" type="image/png" />
  <link rel="apple-touch-icon" href="https://images.khaddict.com/icons/khazix-pc-flat.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700;800&display=swap" rel="stylesheet" />

  <!-- Matomo -->
  <script>
    var _paq = window._paq = window._paq || [];
    _paq.push(['trackPageView']);
    _paq.push(['enableLinkTracking']);
    (function() {
      var u="//matomo.khaddict.com/";
      _paq.push(['setTrackerUrl', u+'matomo.php']);
      _paq.push(['setSiteId', '1']);
      var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
      g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
    })();
  </script>
  <!-- End Matomo -->

  <style>
{% include "partials/head_tokens.css.j2" %}
{% include "partials/status_widget.css.j2" %}
    /* projects */
    .projects {
      flex: 1;
      padding: 3rem 1.5rem 4rem;
      animation: fade-up .45s ease both;
    }

    .projects-inner { max-width: 1040px; margin: 0 auto; }

    .projects-intro { text-align: center; margin-bottom: 2.5rem; }

    .projects-intro h1 {
      font-size: clamp(1.5rem, 4vw, 2.1rem);
      font-weight: 700;
      letter-spacing: -.02em;
      margin-bottom: .6rem;
    }

    .projects-intro .highlight {
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.25rem;
    }

    .project-card {
      display: flex;
      flex-direction: column;
      padding: 1.4rem 1.5rem;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--surface);
      transition: border-color .15s ease, transform .15s ease;
    }
    .project-card:hover { border-color: var(--accent); transform: translateY(-2px); }

    .project-name {
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: -.01em;
      margin-bottom: .55rem;
    }

    .project-desc {
      font-size: .76rem;
      color: var(--muted);
      line-height: 1.55;
      margin-bottom: 1rem;
      flex: 1;
    }

    .project-stack {
      display: flex;
      flex-wrap: wrap;
      gap: .4rem;
      margin-bottom: 1rem;
    }
    .project-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: .68rem;
      color: var(--muted);
      background: var(--bg);
      border: 1px solid var(--border);
      padding: .2rem .55rem;
      border-radius: 10px;
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: .78rem;
      color: var(--accent);
      text-decoration: none;
    }
    .project-link:hover { color: var(--accent-2); }
    .project-link svg { width: 13px; height: 13px; }

    .project-badge {
      display: inline-flex;
      align-self: flex-start;
      font-family: 'JetBrains Mono', monospace;
      font-size: .74rem;
      font-weight: 600;
      color: var(--muted);
      background: var(--bg);
      border: 1px dashed var(--border);
      padding: .3rem .7rem;
      border-radius: 8px;
    }

    @media (max-width: 460px) {
      .projects-grid { grid-template-columns: 1fr; }
    }

    @keyframes fade-up {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
{% include "partials/responsive.css.j2" %}
  </style>
</head>

